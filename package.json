{
  "name": "iptv-web-player",
  "version": "0.4.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "install": "node -e \"if(process.platform === 'win32') require('child_process').execSync('node-gyp rebuild', {stdio: 'inherit'})\"",
    "electron-dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npx -y cross-env ELECTRON_BUILD=true npm run build && electron-builder",
    "electron-pack": "electron-builder",
    "rebuild": "electron-rebuild -f"
  },
  "build": {
    "appId": "com.frame.iptv-player",
    "productName": "FRAME IPTV Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/Release/mpv_renderer.node",
        "to": "mpv_renderer.node"
      }
    ],
    "extraFiles": [
      {
        "from": "libmpv-2.dll",
        "to": "."
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/web-app-manifest-512x512.png"
    }
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/video.js": "^7.3.58",
    "@vidstack/react": "^1.12.13",
    "artplayer": "^5.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.3",
    "hls.js": "^1.6.15",
    "idb-keyval": "^6.2.2",
    "iptv-playlist-parser": "^0.15.1",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "nanoid": "^5.1.6",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "node-addon-api": "^8.5.0",
    "pg": "^8.16.3",
    "plyr": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "video.js": "^8.23.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "prisma": "^7.2.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}